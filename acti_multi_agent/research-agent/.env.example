# Research Agent local environment
# 复制为 .env 后填写；真实 .env 已被 .gitignore 忽略

# ============================================================
# 必填: Anthropic
# Phase 2 / 2.5 / 3 / 3.5 / 3.7 / 4 / 5 需要
# ============================================================
ANTHROPIC_API_KEY=


# ============================================================
# 建议填写: OpenAlex polite pool / 搜索主骨架
# ============================================================
OPENALEX_MAILTO=
OPENALEX_API_KEY=


# ============================================================
# 可选但推荐: Semantic Scholar
# 用于 citation intents / recommendations / SPECTER2
# ============================================================
S2_API_KEY=


# ============================================================
# 建议填写: Crossref identity layer
# 用于 DOI 权威元数据、publisher、license、retraction/update 信号
# ============================================================
CROSSREF_MAILTO=
CROSSREF_TOOL_NAME=research-agent
CROSSREF_PLUS_API_TOKEN=


# ============================================================
# 可选: OpenCitations fallback
# 用于 DOI-to-DOI citation/reference fallback
# 如果接口偏慢，可调小超时
# ============================================================
OPENCITATIONS_ACCESS_TOKEN=
OPENCITATIONS_TIMEOUT_SEC=15


# ============================================================
# 可选但推荐: OpenAI direct API
# 这里走的是 platform API，不是 ChatGPT 网页订阅
# 本仓库通过 /v1/responses 直接调 GPT-5.4 及其 reasoning effort
# ============================================================
OPENAI_API_KEY=
OPENAI_REASONING_MODEL=gpt-5.4
OPENAI_REASONING_MEDIUM=medium
OPENAI_REASONING_HIGH=high
OPENAI_REASONING_XHIGH=xhigh


# ============================================================
# Claude 主脑
# ============================================================
MODEL_FAST=claude-sonnet-4-6
MODEL_DEEP=claude-opus-4-6


# ============================================================
# 可选: Nomic Atlas
# ============================================================
NOMIC_API_KEY=


# ============================================================
# scite
# 当前仓库还没有正式接入 scite 工具层
# 先准备账号/订阅即可；后续若确认接法再补配置项
# ============================================================


# ============================================================
# 其余本地参数
# ============================================================
TARGET_SCORE=0.8
CHROMADB_PATH=
CORPUS_SIZE_THRESHOLD_FOR_GRAPHRAG=500
CORPUS_SIZE_THRESHOLD_FOR_COSMOGRAPH=500
MAILTO=
